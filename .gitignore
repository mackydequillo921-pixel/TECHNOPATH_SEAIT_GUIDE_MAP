# Django
backend_django/staticfiles/
backend_django/media/

# Flutter archive (keep files, ignore build artifacts inside)
_flutter_archive/build/
_flutter_archive/.dart_tool/
.aider*

# Node Installers (Security - don't commit binaries)
*.msi
*.zip

# Credentials (Security - never commit passwords)
*Acounts.txt
*accounts.txt
*passwords.txt
*secrets.txt
*.key
*.pem
